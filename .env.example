PORT=8787
HOST=127.0.0.1

# Your Shopify myshopify.com admin domain, for example: your-store.myshopify.com
# A storefront domain like gatekept.in is not usually accepted by the Admin API.
SHOPIFY_SHOP_DOMAIN=

# Option 1: Paste a custom-app Admin API access token here, usually starts with shpat_.
# Option 2: Leave blank and use the OAuth settings below.
SHOPIFY_ADMIN_ACCESS_TOKEN=

# OAuth app credentials from Shopify Dev Dashboard.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SCOPES=read_orders

# Public URL where this backend is hosted, for example https://support.gatekept.in
# This must match the URL configured in the Shopify Dev Dashboard.
APP_URL=

# Keep this current with the API version enabled for your private/custom app.
SHOPIFY_API_VERSION=2026-04

# Customize if your Shiprocket tracking URL differs.
SHIPROCKET_TRACKING_URL_TEMPLATE=https://shiprocket.co/tracking/{awb}

# Comma-separated list of FAQ questions/answers can be edited directly in public/widget.js too.
